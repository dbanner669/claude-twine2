{
  "name": "twine-mcp-server",
  "version": "0.1.0",
  "description": "MCP server that lets Claude directly author and manipulate Twine 2 interactive fiction stories",
  "main": "dist/index.js",
  "bin": {
    "twine-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "figjam-sync": "ts-node-dev --respawn src/figjam-sync/index.ts",
    "figjam-sync:start": "node dist/figjam-sync/index.js",
    "export-ink": "npm run build && node dist/ink-export/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "keywords": [
    "twine",
    "claude",
    "interactive-fiction",
    "mcp",
    "bridge",
    "twine2",
    "twee",
    "harlowe",
    "sugarcube"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mackmar134/claude-twine2.git"
  },
  "homepage": "https://github.com/mackmar134/claude-twine2#readme",
  "bugs": {
    "url": "https://github.com/mackmar134/claude-twine2/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.0",
    "cheerio": "1.0.0",
    "he": "1.2.0",
    "zod": "3.24.0"
  },
  "devDependencies": {
    "@types/he": "^1.2.3",
    "@types/node": "22.0.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
