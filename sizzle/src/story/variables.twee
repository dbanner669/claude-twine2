:: variables
<<silently>>

/* ============================================================
   AVATAR STATE — 6-layer compositing system
   Layers render bottom-to-top: background -> body -> bodyMods ->
   underwear -> clothing -> foreground
   ============================================================ */
<<set $avatar = {
    background: [],
    body: [],
    bodyMods: [],
    underwear: [],
    clothing: [],
    foreground: [],
    blink: false,
    barefoot: false,
    cleavage: false,
    showRear: false,
    rearViewEnabled: false
}>>
<<set $avatar.top to 0>>

/* ============================================================
   UI SETTINGS
   ============================================================ */
<<set $ui = {
    avatarSize: 1,
    textSize: 1
}>>

/* Header state — populated per-passage by <<header>> widget */
<<set $header to {}>>

/* Temporary per-passage state — reset on each passage transition */
<<set $temp to {}>>

/* ============================================================
   PLAYER CHARACTER
   ============================================================ */
<<set $player = {
    age: 27,
    firstName: "Alex",
    surname: "Morgan",
    background: "",
    complexion: "light",
    nationality: "canadian",
    kinks: [],
    quirks: [],
    storyTags: [],
    attributes: {},
    statusEffects: [],
    personalBio: [],
    achievements: [],
    skills: {},
    isWearing: [],
    piercings: [],
    tattoos: [],
    hairColour: "Brown",
    hairStyle: "Short bob",
    eyeColour: "Blue",
    eyeShape: "Almond",
    faceShape: "oval",
    noseShape: "Celestial",
    mouthShape: "Cupid",
    arousal: 0,
    incitingIncident: ""
}>>

/* Cover identity — the persona used inside Sizzle
   Not defined during character creation. Established in-story. */
<<set $player.cover = {
    firstname: "",
    knownAs: "",
    surname: ""
}>>
<<set $player.codename to "">>

/* Skill initialization
   Skills: academic, agent, athlete, confrontation, charmer,
           streetwise, composure, sexology */
<<set _skillNames to ["academic","agent","athlete","confrontation","charmer","streetwise","composure","sexology"]>>
<<for _i to 0; _i lt _skillNames.length; _i++>>
    <<set $player.skills[_skillNames[_i]] to {level: -4, xp: 0, specialities: []}>>
<</for>>

/* ============================================================
   GAME STATE
   ============================================================ */
<<set $date to {
    year: 2005,
    month: 9,
    day: 12,
    hour: 8,
    dayOfWeek: "Monday"
}>>

<<set $sizzle to {
    suspicion: 0,
    accessLevel: 0,
    reputation: 0
}>>

/* ============================================================
   NYSE TRACKING — hidden from the player
   influence: how affected the player is by NYSE phenomena
              goes up/down but does NOT decay naturally
              starting value set by inciting incident choice
   power:     the player developing abilities of their own
              dormant in early game, manifests later
   ============================================================ */
<<set $nyse to {
    influence: 0,
    power: 0
}>>

/* ============================================================
   IMAGE PATHS — media sits alongside output.html
   ============================================================ */
<<set $imagePath = {
    base: "media/",
    avatar: "media/avatar/",
    ui: "media/ui/"
}>>

/* ============================================================
   NOTIFICATION SYSTEM
   ============================================================ */
<<set $notifications = {
    list: []
}>>

/* ============================================================
   STATISTICS TRACKING
   ============================================================ */
<<set $statistics = new Map()>>

/* ============================================================
   SETUP NAMESPACE — static data (name lists, constants)
   ============================================================ */

<<set setup.backgrounds to [
    "RCMP constable",
    "CSIS analyst",
    "grad student",
    "unemployed after university"
]>>

<<set setup.firstNames to ["Alex", "Sam", "Jordan", "Casey", "Riley",
    "Morgan", "Taylor", "Quinn", "Avery", "Blake",
    "Cameron", "Drew", "Ellis", "Finley", "Harper",
    "Kelly", "Logan", "Parker", "Sage", "Val"]>>

<<set setup.surnames to ["Anderson", "Belanger", "Chen", "Duval", "Edwards",
    "Fletcher", "Grant", "Hayes", "Ivanov", "Jensen",
    "Kessler", "Lawson", "Monroe", "Nash", "Okafor",
    "Palmer", "Quinn", "Reeves", "Singh", "Tremblay"]>>

<<set setup.codenames to ["Falcon", "Ghost", "Hawk", "Jackal", "Lynx",
    "Mantis", "Osprey", "Phantom", "Raven", "Viper",
    "Wolf", "Cobra", "Eagle", "Fox", "Panther"]>>

<<set setup.complexions to ["light", "medium", "dark"]>>

<<set setup.glossary to {
    "NYSE": "Not Yet Scientifically Explained",
    "Branch": "The undisclosed federal Canadian agency that tracks NYSE phenomena. No public name, no signage; everyone inside calls it 'the Branch.' The player's and Robert's employer.",
    "OC Transpo": "Ottawa's public transit operator. Runs the city's buses (and later light rail). On Bank Street, the diesel coaches grinding past are the unmistakable sound of an Ottawa weekday morning.",
    "Globe": "The Globe and Mail — Canada's national daily newspaper of record. Centre-right, broadsheet, the paper a mid-level federal bureaucrat reads with his coffee.",
    "Métis": "One of three constitutionally recognized Indigenous peoples of Canada, alongside First Nations and Inuit. Distinct nation arising from intermarriage between European fur traders and Indigenous (largely Cree, Ojibwe, and Saulteaux) communities, with its own language (Michif), culture, and homeland centred on the Prairies and extending east into Northern Ontario.",
    "Shield country": "The Canadian Shield. Vast Precambrian-rock landscape of boreal forest, lakes, and exposed bedrock covering most of Northern Ontario, Quebec, Manitoba, and the territories. Old land. Hard winters.",
    "Sault": "Sault Ste. Marie — small city on the St. Marys River at the Ontario–Michigan border. Steel town, paper town, gateway between the Great Lakes. Pronounced 'Soo.'",
    "Thunder Bay": "City on the north shore of Lake Superior in Northwestern Ontario. Roughly halfway between Toronto and Winnipeg by distance, but culturally closer to the Prairies than to the GTA. Home of Lakehead University.",
    "Bank Street": "Major north–south arterial running through central Ottawa — from Parliament Hill down through the Glebe and Centretown into the inner suburbs. Civil-service commute corridor, diners, second-hand shops, the city's working spine."
}>>

<</silently>>
