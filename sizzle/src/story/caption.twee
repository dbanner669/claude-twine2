:: StoryCaption
<<nobr>>
<<avatar>>
<</nobr>>


:: AvatarMeta
<<nobr>>
<<if $player.cover && $player.cover.knownAs>>
  <div class="display-name"><<print $player.cover.knownAs>></div>
  <<if $player.cover.coverTitle>>
    <div class="kicker"><<print $player.cover.coverTitle>></div>
  <</if>>
<<else>>
  <div class="display-name"><<print $player.firstName>> <<print $player.surname>></div>
  <div class="kicker">Branch Agent</div>
<</if>>
<div class="stat-bar">
  <span class="stat-label">Composure</span>
  <div class="pips">
    <<set _compLevel to Math.max(0, $player.skills.composure.level + 4)>>
    <<set _compMax to 7>>
    <<for _i to 0; _i lt _compMax; _i++>>
      <<if _i lt _compLevel>>
        <div class="pip --on"></div>
      <<else>>
        <div class="pip"></div>
      <</if>>
    <</for>>
  </div>
</div>
<</nobr>>


:: FooterStatus
<<nobr>>
SAVED · <<print String($date.day).padStart(2,'0')>> <<print ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"][$date.month - 1]>> · <<print String($date.hour).padStart(2,'0')>>:<<print String(Math.floor(Math.random()*60)).padStart(2,'0')>>
<</nobr>>
