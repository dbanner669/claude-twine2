:: PALE-135 Don't look up [nobr avatar-pale-night nighttime]
<<silently>>
<<set $header.location to "HOTEL LOUNGE ALCOVE">>
<<set $header.time to "Monday evening">>
<</silently>>
<<header>>
<<page>>
/* %%% HUMAN-DRAFT %%%
   PALE-135 Don't look up — Near-miss: the woman's gaze sweeps and PC has to break sightline; the pull of being noticed.
   Intent: structural placeholder only; includes moderate Composure/Agent check to stay unseen. ~90 words.
   %%% END %%% */

<<set _composureSkill to (typeof $player.currentComposure === "number") ? $player.currentComposure : $player.skills.composure.level>>
<<set _checkSkill to Math.max(_composureSkill, $player.skills.agent.level)>>
<<skillCheck "Composure / Agent" "2d6" _checkSkill 8>>
<<success>>
<<set $player.flags.paleUnseen to true>>
