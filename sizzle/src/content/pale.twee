:: PALE-165 Impact [nobr avatar-pale-night nighttime]
<<silently>>
<<if not $player.flags.paleInfluenceGranted>>
    <<set _paleInfluence to 1>>
    <<if $player.flags.paleGazeGrazed or $player.flags.paleCommandBitten>>
        <<set _paleInfluence to 2>>
    <</if>>
    <<set $nyse.influence += _paleInfluence>>
    <<set $player.flags.paleInfluenceGranted to true>>
<</if>>
<<if not $player.flags.paleSkillGranted>>
    <<if $player.flags.paleUnseen or $player.flags.paleRuleRead>>
        <<set $player.skills.agent.level += 1>>
    <<elseif $player.flags.paleLoopholeReasoned>>
        <<set $player.skills.academic.level += 1>>
    <<elseif $player.flags.paleCommandHeld>>
        <<set $player.skills.composure.level += 1>>
    <<else>>
        <<set $player.skills.confrontation.level += 1>>
    <</if>>
    <<set $player.flags.paleSkillGranted to true>>
<</if>>
<<set $header.location to "HOTEL LOUNGE ALCOVE">>
<<set $header.time to "Monday evening">>
<</silently>>
<<header>>
<<page>>
/* %%% HUMAN-DRAFT %%%
   PALE-165 Impact — The blow connects, the woman drops, the flat voice stops, and silence sits under the rain.
   Intent: structural placeholder only; guarded NYSE influence and skill grant fire here. ~90 words.
   %%% END %%% */

[[The room comes back to itself.|PALE-170 The room comes back]]
<</page>>


