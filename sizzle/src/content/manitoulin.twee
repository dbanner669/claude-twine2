:: MAN-175 Cut wire [nobr avatar-man-night nighttime]
<<silently>>
<<if not $player.flags.manInfluenceGranted>>
    <<set _manInfluence to 2>>
    <<if $player.flags.manSunroomFailed or $player.flags.manFocalFailed>>
        <<set _manInfluence to 3>>
    <</if>>
    <<set $nyse.influence += _manInfluence>>
    <<set $player.flags.manInfluenceGranted to true>>
<</if>>
<<if not $player.flags.manSkillGranted>>
    <<if $player.flags.manFocalHeld>>
        <<set $player.skills.composure.level += 1>>
    <<elseif $player.flags.manStructureReasoned>>
        <<set $player.skills.academic.level += 1>>
    <<else>>
        <<set $player.skills.confrontation.level += 1>>
    <</if>>
    <<set $player.flags.manSkillGranted to true>>
<</if>>
<<set $header.location to "PRIVATE DOCK">>
<<set $header.time to "Saturday night">>
<</silently>>
<<header>>
<<page>>
