:: StoryCaption
<<nobr>>
<<avatar>>
<</nobr>>


:: AvatarMeta
<<nobr>>
<<if $player.cover && $player.cover.knownAs>>
  <div class="display-name"><<print $player.cover.knownAs>></div>
  <<if $player.cover.coverTitle>>
    <div class="kicker"><<print $player.cover.coverTitle>></div>
  <</if>>
<<else>>
  <div class="display-name"><<print $player.firstName>> <<print $player.surname>></div>
  <div class="kicker">Branch Agent</div>
<</if>>
<div class="stat-bar">
  <span class="stat-label">Composure</span>
  <div class="pips">
    <<set _compMax to setup.composureMax || 7>>
    <<set _compCurrent to (typeof $player.currentComposure === "number") ? $player.currentComposure : $player.skills.composure.level>>
    <<set _compLevel to Math.max(0, Math.min(_compMax, _compCurrent))>>
    <<for _i to 0; _i lt _compMax; _i++>>
      <<if _i lt _compLevel>>
        <div class="pip --on"></div>
      <<else>>
        <div class="pip"></div>
      <</if>>
    <</for>>
  </div>
</div>
<</nobr>>


:: FooterStatus
<<nobr>>
<<set _monthName to (setup.monthNames && setup.monthNames[$date.month - 1]) ? setup.monthNames[$date.month - 1] : "September">>
<<set _slotLabel to (setup.timeSlotLabels && setup.timeSlotLabels[$date.slot]) ? setup.timeSlotLabels[$date.slot] : "Morning">>
<<print _monthName>> <<print $date.day>>, <<print $date.year>> · <<print _slotLabel>>
<</nobr>>
