; Engine configuration file.
; Sizzle — greenfield Godot build (see sizzle/docs/GODOT-PORT-PLAN.md)
config_version=5

[application]

config/name="Sizzle"
run/main_scene="res://scenes/game_shell.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")

[autoload]

State="*res://autoload/state.gd"
Rules="*res://autoload/rules.gd"
StoryBridge="*res://autoload/story_bridge.gd"
SaveManager="*res://autoload/save_manager.gd"
ThemeService="*res://autoload/theme_service.gd"
AvatarManifest="*res://autoload/avatar_manifest.gd"
Settings="*res://autoload/settings.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[dotnet]

project/assembly_name="Sizzle"

[editor_plugins]

enabled=PackedStringArray("res://addons/GodotInk/plugin.cfg", "res://addons/gut/plugin.cfg")
